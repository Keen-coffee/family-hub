# Server configuration
PORT=3001
NODE_ENV=development

# Security
SESSION_SECRET=change-this-to-a-random-secret-string

# CalDAV (Nextcloud, Radicale, etc.)
CALDAV_URL=https://your-caldav-server/remote.php/dav
CALDAV_USERNAME=your-username
CALDAV_PASSWORD=your-password

# Tandoor Recipes
TANDOOR_URL=http://your-tandoor-instance
TANDOOR_API_TOKEN=your-tandoor-api-token

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_UNITS=imperial

# Database (SQLite path)
DB_PATH=./data/familyhub.db
